<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">


        <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/titleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Auto Clicker Demo"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="目前點位數：0"
                android:textSize="18sp" />

            <Button
                android:id="@+id/addPointButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="新增點位" />

            <TextView
                android:id="@+id/listText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="(尚無點位資料)"
                android:textSize="16sp" />

            <Button
                android:id="@+id/removePointButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="刪除最後一個點位" />

            <EditText
                android:id="@+id/removeIdInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="輸入要刪除的點位 ID"
                android:inputType="number" />

            <Button
                android:id="@+id/removeByIdButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="刪除指定 ID 點位" />

            <Button
                android:id="@+id/EditButtonUp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="ID選擇向上" />

            <Button
                android:id="@+id/EditButtonDown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="ID選擇向下" />

            <TextView
                android:id="@+id/ChooseButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="(尚無點位資料)"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/editXRatioInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="輸入 xRatio，例如 0.5"
                android:inputType="numberDecimal" />

            <EditText
                android:id="@+id/editYRatioInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="輸入 yRatio，例如 0.5"
                android:inputType="numberDecimal" />

            <EditText
                android:id="@+id/editDelayInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="輸入 delay 毫秒，例如 500"
                android:inputType="number" />

            <EditText
                android:id="@+id/editDurationInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="輸入 duration 毫秒，例如 100"
                android:inputType="number" />

            <Button
                android:id="@+id/applyEditButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="套用修改" />
        </LinearLayout>

    </LinearLayout>

</ScrollView>